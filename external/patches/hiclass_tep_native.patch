+/* ============================================================
+ * TEP (Temporal Equivalence Principle) Background-Only Modification
+ * ============================================================
+ * Native TEP implementation: H_TEP(z) = H_LCDM(z) * M(z)
+ *   where M(z) = A(z) / (1 - alpha_A(z)) is the exact Jordan-frame factor.
+ *   A(z) = exp(epsilon_T * log(1+z) * S(z)) is the covariant conformal factor.
+ *   S(z) = exp(-(z/z_T)^n_T) is the early-universe suppression.
+ * (Background expansion governed by disformal metric; A(z) multiplies null-geodesic distances.)
+ * Authoritative transition function from TEP-C0 (Paper 26 "Athens";
+ * core/cosmology.py:conformal_factor_native):
+ *
+ *     f_T(z) = ln(1+z) * exp(-(z/z_T)^n_T)
+ *
+ * Two factors enforce the physics required by Paper 26 (Secs. 4.3 and 8):
+ *   - exp(-(z/z_T)^n_T)  : "early-time freezing via exponential suppression".
+ *       The temporal-shear field is suppressed for z >> z_T, so the
+ *       pre-recombination sound horizon r_s, BBN, and the CMB acoustic peaks
+ *       are preserved by construction (f_T -> 0 at recombination).
+ *   - ln(1+z)            : guarantees f_T(0) = 0, fixing the local reference
+ *       frame so H0 is unmodified; the enhancement turns on only for z > 0.
+ *
+ * HISTORICAL BUG (fixed here): the previous form  f_T = 1 - exp(-(z/z_T)^n)
+ * is the COMPLEMENT of the suppression and saturates to 1 for z >> z_T,
+ * i.e. it applied the FULL Hubble modification at recombination. That
+ * inverted the intended freezing mechanism and shifted the acoustic scale
+ * theta_s by ~0.3% (~11 sigma for Planck), producing spurious few-percent
+ * C_ell residuals. No high-z cap is needed any more: exp() handles z >> z_T.
+ * ============================================================ */
+
+/* TEP transition suppression factor S(z) = exp(-(z/z_T)^n_T).
+   Matches TEP-C0 (Paper 26) compiled CLASS exactly.
+   The full transition is ln(1+z) * S(z), computed in tep_gamma_factor. */
+double tep_f_transition(struct background *pba, double z) {
+  if (pba->tep_mode == _FALSE_ || pba->epsilon_T == 0.0 || z <= 0.0) {
+    return 0.0;
+  }
+  double z_effective = z;
+  if (pba->z_T > 0.0 && z > pba->z_T * 3.0) {
+    z_effective = pba->z_T * 3.0;
+  }
+  double ratio = z_effective / pba->z_T;
+  double exponent = pow(ratio, pba->n_T);
+  return exp(-exponent);
+}
+
+/* TEP gamma factor: A(z) = exp(epsilon_T * log(1+z) * S(z))
+   Exact covariant conformal factor (not linearized).
+   S(z) = tep_f_transition(z) is the suppression factor alone. */
+double tep_gamma_factor(struct background *pba, double z) {
+  if (pba->tep_mode == _FALSE_ || pba->epsilon_T == 0.0) {
+    return 1.0;
+  }
+  double S_z = tep_f_transition(pba, z);
+  double log_factor = log(1.0 + z);
+  double A_phi = exp(pba->epsilon_T * log_factor * S_z);
+  if (A_phi < 0.1) A_phi = 0.1;
+  return A_phi;
+}
+
+/* TEP Jordan-frame M factor: M(z) = A(z) / (1 - alpha_A(z))
+   Exact covariant conformal transformation.
+   For A = exp(g) with g = epsilon_T * log(1+z) * S(z):
+   alpha_A = dlnA/dln(1+z) = -(1+z)*dg/dz
+           = -epsilon_T * (S(z) + (1+z)*log(1+z)*dS/dz) */
+double tep_M_factor(struct background *pba, double z) {
+  if (pba->tep_mode == _FALSE_ || pba->epsilon_T == 0.0 || z <= 0.0) {
+    return 1.0;
+  }
+  double A_z = tep_gamma_factor(pba, z);
+  double S_z = tep_f_transition(pba, z);
+  double dS = 0.0;
+  if (z > 1e-10 && pba->z_T > 0.0 && z <= pba->z_T * 3.0) {
+    dS = -S_z * pba->n_T * pow(z / pba->z_T, pba->n_T - 1.0) / pba->z_T;
+  }
+  double alpha_A = -(pba->epsilon_T) * (S_z + (1.0 + z) * log(1.0 + z) * dS);
+  return A_z / (1.0 - alpha_A);
+}
+
+/* Modified Hubble rate with TEP */
+double tep_hubble_rate(struct background *pba, double z, double H_lcdm) {
+  double M = tep_M_factor(pba, z);
+  return H_lcdm * M;
+}
+
+/* Validate and log TEP parameters */
+int tep_background_init(struct background *pba) {
+  if (pba->tep_mode == _TRUE_) {
+    class_test(pba->epsilon_T < 0.0,
+               pba->error_message,
+               "TEP error: epsilon_T must be non-negative");
+    class_test(pba->z_T <= 0.0,
+               pba->error_message,
+               "TEP error: z_T must be positive");
+    class_test(pba->n_T <= 0.0,
+               pba->error_message,
+               "TEP error: n_T must be positive");
+  }
+  return _SUCCESS_;
+}
